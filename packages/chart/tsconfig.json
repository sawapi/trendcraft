{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "types": ["vitest/globals", "node", "react", "react-dom"]
  },
  "include": ["src/**/*", "react/**/*", "vue/**/*"],
  "exclude": ["node_modules", "dist"]
}
