{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@trendcraft/chart": ["../../src/index.ts"],
      "@trendcraft/chart/presets": ["../../src/presets.ts"],
      "trendcraft": ["../../../core/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
