{
  "name": "@trendcraft/chart",
  "version": "0.1.0",
  "description": "Finance-specialized charting library with native TrendCraft Series<T> support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.js",
      "require": "./dist/presets.cjs"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "import": "./dist/headless.js",
      "require": "./dist/headless.cjs"
    },
    "./react": {
      "types": "./dist/react/TrendChart.d.ts",
      "import": "./dist/react/TrendChart.js",
      "require": "./dist/react/TrendChart.cjs"
    },
    "./vue": {
      "types": "./dist/vue/TrendChart.d.ts",
      "import": "./dist/vue/TrendChart.js",
      "require": "./dist/vue/TrendChart.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.test.*",
    "!dist/**/*.js.map",
    "!dist/**/*.cjs.map",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "size-check": "size-limit",
    "format": "biome format --write ."
  },
  "keywords": [
    "chart",
    "candlestick",
    "finance",
    "trading",
    "technical-analysis",
    "canvas",
    "trendcraft"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sawapi/trendcraft.git",
    "directory": "packages/chart"
  },
  "bugs": {
    "url": "https://github.com/sawapi/trendcraft/issues"
  },
  "author": "sawapi",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "trendcraft": ">=0.1.0",
    "react": ">=18.0.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "trendcraft": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "size-limit": [
    {
      "name": "Main (createChart + all exports)",
      "path": "dist/index.js",
      "limit": "31 kB"
    },
    {
      "name": "Headless API",
      "path": "dist/headless.js",
      "limit": "11 kB"
    },
    {
      "name": "React wrapper",
      "path": "dist/react/TrendChart.js",
      "limit": "27 kB"
    },
    {
      "name": "Vue wrapper",
      "path": "dist/vue/TrendChart.js",
      "limit": "27 kB"
    }
  ],
  "devDependencies": {
    "@size-limit/esbuild": "^12.0.1",
    "@size-limit/file": "^12.0.1",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "vue": "^3.5.0",
    "size-limit": "^12.0.1",
    "trendcraft": "workspace:*",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
