{
  "name": "trendcraft",
  "version": "0.2.0",
  "description": "Technical analysis library for TypeScript — 130+ indicators, backtesting, optimization, streaming, and zero dependencies",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "trendcraft-screen": "./dist/bin/trendcraft-screen.js",
    "trendcraft-backtest": "./dist/bin/trendcraft-backtest.js",
    "trendcraft-analyze": "./dist/bin/trendcraft-analyze.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./screening": {
      "types": "./dist/screening/index.d.ts",
      "import": "./dist/screening/index.js",
      "require": "./dist/screening/index.cjs"
    },
    "./incremental": {
      "types": "./dist/indicators/incremental/index.d.ts",
      "import": "./dist/indicators/incremental/index.js",
      "require": "./dist/indicators/incremental/index.cjs"
    },
    "./safe": {
      "types": "./dist/indicators/safe/index.d.ts",
      "import": "./dist/indicators/safe/index.js",
      "require": "./dist/indicators/safe/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/__benchmarks__",
    "!dist/**/*.js.map",
    "!dist/**/*.cjs.map",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "analyze": "npx tsx bin/trendcraft-analyze.ts",
    "test:crossval": "vitest run cross-validation",
    "bench": "vitest bench",
    "size": "size-limit",
    "qa:indicators": "node scripts/qa-sweep.mjs",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "trading",
    "technical-analysis",
    "indicators",
    "backtesting",
    "optimization",
    "streaming",
    "sma",
    "ema",
    "rsi",
    "macd",
    "bollinger-bands",
    "ichimoku",
    "vwap",
    "smart-money",
    "screening",
    "finance",
    "stocks",
    "crypto"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sawapi/trendcraft.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sawapi/trendcraft#readme",
  "bugs": {
    "url": "https://github.com/sawapi/trendcraft/issues"
  },
  "author": "sawapi",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "500 kB"
    },
    {
      "path": "dist/index.cjs",
      "limit": "400 kB"
    }
  ],
  "devDependencies": {
    "@size-limit/file": "^12.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "size-limit": "^12.0.1",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
