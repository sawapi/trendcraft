{
  "name": "@trendcraft/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for TrendCraft — exposes 96+ indicator manifests (whenToUse / pitfalls / synergy / regime) plus a single calc dispatcher to LLM clients like Claude Desktop and Cursor",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "trendcraft-mcp": "./dist/bin/trendcraft-mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.test.*",
    "!dist/**/*.js.map",
    "!dist/**/*.cjs.map",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "EXAMPLES.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node ./dist/bin/trendcraft-mcp.js",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "trading",
    "technical-analysis",
    "indicators",
    "trendcraft"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sawapi/trendcraft.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/sawapi/trendcraft#readme",
  "bugs": {
    "url": "https://github.com/sawapi/trendcraft/issues"
  },
  "author": "sawapi",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "trendcraft": "workspace:^",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
